<Window x:Class="MarfinaWpfApp03.PartnerEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование партнера" 
        Height="600" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock x:Name="TitleTextBlock" 
                   FontSize="20" 
                   FontWeight="Bold" 
                   Margin="0,0,0,20"
                   Grid.Row="0"/>

        <!-- Форма ввода -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Тип партнера -->
                <TextBlock Text="Тип партнера*" FontWeight="Bold" Margin="0,5"/>
                <ComboBox x:Name="TypeComboBox" 
                         DisplayMemberPath="Name"
                         SelectedValuePath="Id"
                         Margin="0,0,0,10"
                         Height="30"/>

                <!-- Наименование -->
                <TextBlock Text="Наименование*" FontWeight="Bold" Margin="0,5"/>
                <TextBox x:Name="NameTextBox" 
                        Margin="0,0,0,10"
                        Height="30"/>

                <!-- Рейтинг -->
                <TextBlock Text="Рейтинг*" FontWeight="Bold" Margin="0,5"/>
                <TextBox x:Name="RatingTextBox" 
                        Margin="0,0,0,10"
                        Height="30"
                        PreviewTextInput="NumberValidationTextBox"/>

                <!-- Юридический адрес -->
                <TextBlock Text="Юридический адрес" FontWeight="Bold" Margin="0,5"/>
                <TextBox x:Name="AddressTextBox" 
                        Margin="0,0,0,10"
                        Height="30"
                        TextWrapping="Wrap"/>

                <!-- ФИО директора -->
                <TextBlock Text="ФИО директора" FontWeight="Bold" Margin="0,5"/>
                <TextBox x:Name="DirectorTextBox" 
                        Margin="0,0,0,10"
                        Height="30"/>

                <!-- Телефон -->
                <TextBlock Text="Телефон" FontWeight="Bold" Margin="0,5"/>
                <TextBox x:Name="PhoneTextBox" 
                        Margin="0,0,0,10"
                        Height="30"/>

                <!-- Email -->
                <TextBlock Text="Email" FontWeight="Bold" Margin="0,5"/>
                <TextBox x:Name="EmailTextBox" 
                        Margin="0,0,0,10"
                        Height="30"/>

                <TextBlock Text="* - обязательные поля" 
                          Foreground="Gray" 
                          FontSize="11"
                          Margin="0,10"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Кнопки -->
        <StackPanel Grid.Row="2" 
                   Orientation="Horizontal" 
                   HorizontalAlignment="Right"
                   Margin="0,20,0,0">
            <Button Content="Сохранить" 
                    Click="Save_Click"
                    Width="100" 
                    Height="35"
                    Margin="0,0,10,0"
                    Background="#27ae60"
                    Foreground="White"
                    BorderThickness="0"/>
            <Button Content="Отмена" 
                    Click="Cancel_Click"
                    Width="100" 
                    Height="35"
                    Background="#e74c3c"
                    Foreground="White"
                    BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Window>