<Window x:Class="MarfinaWpfApp03.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:MarfinaWpfApp03"
        Title="Меню программы" 
        Height="550" 
        Width="1000"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <!-- Конвертер для перевода Boolean в Visibility -->
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>
        <Style x:Key="HeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Foreground" Value="#2c3e50"/>
        </Style>

        <Style x:Key="SubHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="10,5"/>
            <Setter Property="Foreground" Value="#34495e"/>
        </Style>

        <Style x:Key="ButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="#3498db"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2980b9"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource ButtonStyle}">
            <Setter Property="Background" Value="#e74c3c"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#c0392b"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <DockPanel Margin="10">
        <!-- МЕНЮ ПРОГРАММЫ СВЕРХУ -->
        <Menu DockPanel.Dock="Top" Margin="0,0,0,10">
           
            <MenuItem Header="Действия с партнерами">
                <MenuItem Header="Добавить партнера" Click="AddPartner_Click"/>
                <MenuItem Header="Редактировать партнера" Click="EditPartner_Click"
                      IsEnabled="{Binding SelectedPartner, Converter={StaticResource BoolToVisConverter}}"/>
                <MenuItem Header="Удалить партнера" Click="DeletePartner_Click"
                      IsEnabled="{Binding SelectedPartner, Converter={StaticResource BoolToVisConverter}}"/>
            </MenuItem>
            <MenuItem Header="Действия с продажими" 
              IsEnabled="{Binding SelectedPartner, Converter={StaticResource BoolToVisConverter}}">
                <MenuItem Header="Добавить продажу" Click="AddSale_Click"/>
                <MenuItem Header="Редактировать продажу" Click="EditSale_Click"
                  IsEnabled="{Binding SelectedSale, Converter={StaticResource BoolToVisConverter}}"/>
                <MenuItem Header="Удалить продажу" Click="DeleteSale_Click"
                  IsEnabled="{Binding SelectedSale, Converter={StaticResource BoolToVisConverter}}"/>
            </MenuItem>
            <MenuItem Header="Создать отчет" Click="CreateReport_Click"/>
        </Menu>

        <!-- ОСНОВНОЙ ИНТЕРФЕЙС -->
        <Grid>
            <Grid.ColumnDefinitions>
                <!-- Левая колонка для списка партнеров -->
                <ColumnDefinition Width="400"/>
                <!-- Разделитель -->
                <ColumnDefinition Width="5"/>
                <!-- Правая колонка для списка заказов -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ЛЕВАЯ КОЛОНКА - СПИСОК ПАРТНЕРОВ -->
            <GroupBox Header="Список партнеров" 
                  Grid.Column="0" 
                  Padding="5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Заголовок списка (без кнопок) -->
                    <TextBlock Grid.Row="0" 
                           Text="Выберите партнера из списка" 
                           Margin="0,0,0,10"
                           Foreground="Gray"
                           FontStyle="Italic"/>

                    <!-- Список партнеров -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ListBox x:Name="PartnersList" 
                             ItemsSource="{Binding Partners}"
                             SelectedItem="{Binding SelectedPartner}"
                             BorderThickness="0"
                             Background="Transparent">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#ddd" 
                                        BorderThickness="1" 
                                        Margin="0,0,0,10" 
                                        Padding="10"
                                        CornerRadius="5"
                                        Background="White">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="60"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Orientation="Vertical">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding TypeName}" 
                                                           FontWeight="Bold" 
                                                           FontSize="12" 
                                                           Foreground="Gray"/>
                                                    <TextBlock Text=" | "/>
                                                    <TextBlock Text="{Binding Name}" 
                                                           FontWeight="Bold" 
                                                           FontSize="14"/>
                                                </StackPanel>
                                                <TextBlock Text="{Binding DirectorName}"/>
                                                <TextBlock Text="{Binding Phone}"/>
                                                <TextBlock>
                                                <Run Text="Рейтинг: "/>
                                                <Run Text="{Binding Rating}"/>
                                                </TextBlock>
                                            </StackPanel>

                                            <!-- Скидка справа -->
                                            <TextBlock Grid.Column="1"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"
                                               FontWeight="Bold"
                                               FontSize="16"
                                               Text="{Binding DiscountPercent, StringFormat={}{0}%}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </ScrollViewer>
                </Grid>
            </GroupBox>

            <!-- РАЗДЕЛИТЕЛЬ МЕЖДУ КОЛОНКАМИ -->
            <GridSplitter Grid.Column="1" 
                      Width="5" 
                      Background="#3498db" 
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"/>

            <!-- ПРАВАЯ КОЛОНКА - СПИСОК ЗАКАЗОВ ВЫБРАННОГО ПАРТНЕРА -->
            <GroupBox Header="Список заказов выбранного партнера" 
                  Grid.Column="2" 
                  Padding="5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Информация о выбранном партнере сверху -->
                    <Border Grid.Row="0" 
                        Background="#f5f5f5" 
                        Padding="10" 
                        Margin="0,0,0,10"
                        CornerRadius="5"
                        Visibility="{Binding SelectedPartner, Converter={StaticResource BoolToVisConverter}}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding SelectedPartner.TypeName}" FontWeight="Bold" Foreground="Gray"/>
                                <TextBlock Text=" | "/>
                                <TextBlock Text="{Binding SelectedPartner.Name}" FontWeight="Bold" FontSize="16"/>
                            </StackPanel>
                            <TextBlock Text="{Binding SelectedPartner.DirectorName}"/>
                            <TextBlock Text="{Binding SelectedPartner.Phone}"/>
                            <TextBlock Text="{Binding SelectedPartner.Rating, StringFormat='Рейтинг: {0}'}"/>
                        </StackPanel>
                    </Border>

                    <!-- Список заказов -->
                    <DataGrid Grid.Row="1" 
          x:Name="SalesGrid" 
          ItemsSource="{Binding SalesHistory}"
          SelectedItem="{Binding SelectedSale, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
          AutoGenerateColumns="False" 
          IsReadOnly="True"
          RowEditEnding="SalesGrid_RowEditEnding"
          Margin="5"
          SelectionMode="Single"
          SelectionUnit="FullRow">

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Наименование продукции" 
                        Binding="{Binding ProductName}" 
                        Width="*"/>
                            <DataGridTextColumn Header="Количество" 
                        Binding="{Binding Quantity}" 
                        Width="80"/>
                            <DataGridTextColumn Header="Дата продажи" 
                        Binding="{Binding SaleDate, StringFormat=dd.MM.yyyy}" 
                        Width="100"/>
                            <DataGridTextColumn Header="Сумма" 
                        Binding="{Binding TotalAmount, StringFormat=C2}" 
                        Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </GroupBox>
        </Grid>
    </DockPanel>
    </Window>